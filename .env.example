# Grid Wizard OpenClaw Skill - example environment
# Copy to .env and replace placeholders.

# Runtime
APP_ENV=production
LOG_LEVEL=info
DRY_RUN=true
PORT=8787

# XRPL connectivity
XRPL_RPC_URL=https://s1.ripple.com:51234/
XRPL_WS_URL=wss://s1.ripple.com/
XRPL_NETWORK=mainnet

# Wallet / execution identity
TRADER_WALLET_ADDRESS=rXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TRADER_WALLET_SECRET=REPLACE_ME

# Market pair
BASE_ASSET=RLUSD
QUOTE_ASSET=XRP

# Grid configuration
GRID_LEVELS=12
GRID_STEP_PCT=0.35
GRID_NOTIONAL_PER_LEVEL=75
GRID_REBALANCE_INTERVAL_SEC=20

# Risk controls
MAX_OPEN_ORDERS=24
MAX_PENDING_BUYS=8
MAX_PENDING_SELLS=8
MAX_POSITION_BASE=1500
MAX_DAILY_NOTIONAL=10000
HARD_STOP_DRAWDOWN_PCT=6.0

# Optional execution guard
AUTO_CANCEL_DISTANCE_PCT=1.5
AUTO_CANCEL_ENABLED=true

# AI breathing layer
DYNAMIC_GRID_OPTIMIZER_ENABLED=true
DGO_MAX_STEP_MULTIPLIER=1.6
DGO_MIN_STEP_MULTIPLIER=0.7
DIPSCOUNT_ENABLED=true
DIPSCOUNT_MAX_CONSECUTIVE_BUYS=3
DIPSCOUNT_COOLDOWN_SEC=90

# API auth
API_KEY=change-me
